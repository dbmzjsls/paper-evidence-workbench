# LLM generation. Leave empty to use retrieval and extractive fallback only.
DASHSCOPE_API_KEY=

# Paths
PAPER_STORAGE_DIR=./data
UPLOAD_DIR=./data/_uploads
PARSED_DIR=./data/parsed
ASSET_DIR=./data/assets
SQLITE_PATH=./vectorstore/paper_corpus.sqlite3
WEB_DIR=./web
MINERU_OUTPUT_DIR=./data/parsed

# MinerU parsing
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_FORMULA=true
MINERU_TABLE=true
MINERU_IMAGE_ANALYSIS=true
MINERU_TIMEOUT_SECONDS=1200

# Runtime behavior
AUTO_INGEST_ON_STARTUP=false
RETRIEVAL_CONTEXTS=8
SCREEN_DEFAULT_LIMIT=10
SCREEN_MAX_LIMIT=50
KEYWORD_CANDIDATE_LIMIT=500
TRUST_LOCAL_FAISS_INDEX=false
ENABLE_RERANK=false
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATE_LIMIT=50

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
